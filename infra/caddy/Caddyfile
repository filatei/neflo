# Neflo's own ingress. Cloudflare proxies neflo.torama.money to this Caddy on
# :8443 (via a Cloudflare Origin Rule that sets the origin port). Caddy serves
# HTTPS with a Cloudflare Origin Certificate and reverse-proxies the app over
# the private docker network — so Neflo never touches the shared Apache.
#
# Rate limiting / DDoS is handled at the Cloudflare edge (per-hostname), so this
# stays a clean TLS reverse proxy. No mod_evasive, no shared blocklist.

{
	admin off
	# Trust Cloudflare's forwarded client IP.
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
	}
}

neflo.torama.money:8443 {
	# Cloudflare Origin Certificate (15-year) for *.torama.money.
	tls /etc/caddy/origin/cert.pem /etc/caddy/origin/key.pem

	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	reverse_proxy app:3000 {
		# flush_interval -1 disables buffering → Server-Sent Events stream live.
		flush_interval -1
		header_up X-Forwarded-Proto https
		header_up Host {host}
	}
}
