// Neflo — stablecoin-first payments platform
// Postgres + Prisma. Hosted on the same box as Otuburu.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Auth (NextAuth / Auth.js Prisma adapter shape)
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  merchants MerchantMember[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ----------------------------------------------------------------------------
// Merchants (the "platforms" that receive payments)
// ----------------------------------------------------------------------------

model Merchant {
  id              String   @id @default(cuid())
  name            String
  // Settlement currency code, e.g. NGN
  settlementCcy   String   @default("NGN")
  // KYB / activation gate
  status          MerchantStatus @default(PENDING)

  // --- KYB / business profile ---
  // applicantType: BUSINESS (registered) or INDIVIDUAL (name + NIN).
  applicantType           String?  @default("BUSINESS")
  legalName               String?
  // registrationType: RC (company) or BN (business name). registrationNumber
  // holds the digits only (no "RC"/"BN" prefix).
  registrationType        String?
  registrationNumber      String?
  businessType            String?
  // Individual applicants: full name + 11-digit NIN.
  fullName                String?
  nin                     String?
  // Optional uploaded registration certificate (path on the uploads volume).
  certificatePath         String?
  country                 String?  @default("NG")
  phone                   String?
  website                 String?
  address                 String?
  settlementBankCode      String?
  settlementAccountNumber String?
  settlementAccountName   String?
  kybSubmittedAt          DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members          MerchantMember[]
  apiKeys          ApiKey[]
  depositAddresses DepositAddress[]
  deposits         StablecoinDeposit[]
  conversions      Conversion[]
  ledgerEntries    LedgerEntry[]
  webhooks         WebhookEndpoint[]
  balances         MerchantBalance[]
  charges          Charge[]
  payouts          Payout[]
  invites          MerchantInvite[]

  @@map("merchants")
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model MerchantMember {
  id         String       @id @default(cuid())
  merchantId String
  userId     String
  role       MemberRole   @default(OWNER)
  createdAt  DateTime     @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([merchantId, userId])
  @@map("merchant_members")
}

// Pending invitation to join a merchant. Accepted when the invited email signs in.
model MerchantInvite {
  id         String     @id @default(cuid())
  merchantId String
  email      String
  role       MemberRole @default(VIEWER)
  token      String     @unique
  invitedBy  String?
  acceptedAt DateTime?
  createdAt  DateTime   @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([email])
  @@map("merchant_invites")
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

model ApiKey {
  id         String   @id @default(cuid())
  merchantId String
  label      String
  // We store only a hash of the secret; the prefix is shown for identification.
  prefix     String
  hash       String
  mode       ApiMode  @default(TEST)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("api_keys")
}

enum ApiMode {
  TEST
  LIVE
}

// ----------------------------------------------------------------------------
// Stablecoin rails
// ----------------------------------------------------------------------------

enum Chain {
  TRON
  ETHEREUM
  POLYGON
}

enum Asset {
  USDT
  USDC
}

// A per-merchant, per-chain HD-derived deposit address.
// When chargeId is set, the address belongs to a single hosted-checkout charge.
model DepositAddress {
  id           String   @id @default(cuid())
  merchantId   String
  chargeId     String?
  chain        Chain
  address      String
  // BIP44 derivation index used to derive this address from the master seed.
  derivationIx Int
  label        String?
  createdAt    DateTime @default(now())

  merchant Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  charge   Charge?             @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  deposits StablecoinDeposit[]

  @@unique([chain, address])
  @@unique([chain, derivationIx])
  @@index([merchantId])
  @@index([chargeId])
  @@map("deposit_addresses")
}

// Hosted-checkout charge: a shareable payment request.
model Charge {
  id          String       @id @default(cuid())
  merchantId  String
  // Expected amount in USD (USDT/USDC are treated 1:1 with USD).
  amountUsd   Decimal      @db.Decimal(38, 6)
  description String?
  reference   String?
  successUrl  String?
  status      ChargeStatus @default(PENDING)
  // Running total received (USD) across this charge's addresses.
  paidUsd     Decimal      @db.Decimal(38, 6) @default(0)
  expiresAt   DateTime?
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  merchant    Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  addresses   DepositAddress[]
  ngnAccounts NgnVirtualAccount[]
  ngnPayments NgnPayment[]

  @@index([merchantId])
  @@index([status])
  @@map("charges")
}

// A dynamic bank virtual account issued for a single charge (NGN rail).
model NgnVirtualAccount {
  id            String   @id @default(cuid())
  chargeId      String
  merchantId    String
  provider      String // "squad" | "mock"
  accountNumber String
  bankName      String
  accountName   String
  // Provider's reference / customer identifier we created the account with.
  providerRef   String   @unique
  amountKobo    BigInt
  createdAt     DateTime @default(now())

  charge   Charge       @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  payments NgnPayment[]

  @@index([chargeId])
  @@map("ngn_virtual_accounts")
}

// A received NGN payment — for a charge (checkout) OR a merchant deposit
// account (no charge). Source: bank transfer (virtual account) or card/USSD.
model NgnPayment {
  id               String   @id @default(cuid())
  virtualAccountId String?
  chargeId         String?
  merchantId       String
  provider         String
  // "transfer" | "card"
  method           String   @default("transfer")
  // Provider's unique transaction reference — idempotency key.
  transactionRef   String   @unique
  amountKobo       BigInt
  // USD-equivalent at credit time (for the charge's USD-based total).
  usdAmount        Decimal  @db.Decimal(38, 6)
  createdAt        DateTime @default(now())

  virtualAccount NgnVirtualAccount? @relation(fields: [virtualAccountId], references: [id], onDelete: Cascade)
  charge         Charge?            @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([chargeId])
  @@index([merchantId])
  @@map("ngn_payments")
}

// A permanent NUBAN a merchant shares to receive Naira directly (not tied to a
// charge). Inbound transfers credit the merchant's NGN balance.
model MerchantVirtualAccount {
  id            String   @id @default(cuid())
  merchantId    String   @unique
  provider      String
  accountNumber String
  bankName      String
  accountName   String
  providerRef   String   @unique
  createdAt     DateTime @default(now())

  @@map("merchant_virtual_accounts")
}

enum ChargeStatus {
  PENDING
  PAID
  UNDERPAID
  EXPIRED
}

model StablecoinDeposit {
  id            String        @id @default(cuid())
  merchantId    String
  addressId     String
  chain         Chain
  asset         Asset
  // On-chain tx hash; unique so the monitor is idempotent.
  txHash        String
  fromAddress   String?
  // Amount of the stablecoin (6 dp for USDT/USDC) stored as string-decimal.
  amount        Decimal       @db.Decimal(38, 6)
  confirmations Int           @default(0)
  status        DepositStatus @default(DETECTED)
  detectedAt    DateTime      @default(now())
  confirmedAt   DateTime?

  merchant   Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  address    DepositAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  conversion Conversion?

  @@unique([chain, txHash])
  @@index([merchantId])
  @@index([status])
  @@map("stablecoin_deposits")
}

enum DepositStatus {
  DETECTED
  CONFIRMED
  CREDITED
  FAILED
}

// USD-stablecoin -> local currency conversion applied when a deposit is credited.
model Conversion {
  id            String   @id @default(cuid())
  merchantId    String
  depositId     String   @unique
  asset         Asset
  usdAmount     Decimal  @db.Decimal(38, 6)
  // Mid-market USD->local rate used
  rate          Decimal  @db.Decimal(38, 6)
  spreadBps     Int
  // Net local-currency amount credited after spread
  localCcy      String
  localAmount   Decimal  @db.Decimal(38, 2)
  createdAt     DateTime @default(now())

  merchant Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deposit  StablecoinDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("conversions")
}

// Double-entry-friendly ledger. Each credit/debit is one row.
model LedgerEntry {
  id          String       @id @default(cuid())
  merchantId  String
  ccy         String
  // Positive = credit, negative = debit, minor units (kobo for NGN)
  amountMinor BigInt
  kind        LedgerKind
  reference   String?
  createdAt   DateTime     @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("ledger_entries")
}

enum LedgerKind {
  DEPOSIT_CREDIT
  CONVERSION_SPREAD
  PAYOUT_DEBIT
  ADJUSTMENT
}

// Cached running balance per merchant per currency (derived from the ledger).
model MerchantBalance {
  id            String   @id @default(cuid())
  merchantId    String
  ccy           String
  availableMinor BigInt  @default(0)
  updatedAt     DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, ccy])
  @@map("merchant_balances")
}

model WebhookEndpoint {
  id         String   @id @default(cuid())
  merchantId String
  url        String
  secret     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  merchant   Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([merchantId])
  @@map("webhook_endpoints")
}

// One attempt-tracked delivery of an event to an endpoint (with retries).
model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  merchantId     String
  event          String
  // The exact JSON body that was signed and sent.
  payload        String
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  responseStatus Int?
  lastError      String?
  nextRetryAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// An in-flight hosted-gateway (card/USSD) transaction. We record the amount we
// initiated so crediting uses our figure, not the (unit-ambiguous) webhook body.
model GatewayTransaction {
  id         String   @id @default(cuid())
  reference  String   @unique
  chargeId   String
  merchantId String
  amountKobo BigInt
  status     String   @default("PENDING") // PENDING | SUCCESS | FAILED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chargeId])
  @@map("gateway_transactions")
}

// A merchant withdrawal of NGN balance to a bank account.
model Payout {
  id            String       @id @default(cuid())
  merchantId    String
  amountKobo    BigInt
  bankCode      String
  accountNumber String
  accountName   String
  provider      String
  reference     String       @unique
  providerRef   String?
  status        PayoutStatus @default(PENDING)
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// Singleton-ish cursor so the monitor can resume scanning per chain.
model MonitorCursor {
  chain        Chain    @id
  lastBlock    BigInt   @default(0)
  lastScanAt   DateTime @default(now())

  @@map("monitor_cursors")
}
