# ---------- Core ----------
# Public base URL of this deployment
NEXTAUTH_URL=https://neflo.torama.money
APP_URL=https://neflo.torama.money
# Random 32+ byte secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=

# ---------- Database (Postgres on the same box as Otuburu) ----------
DATABASE_URL=postgresql://neflo:neflo@localhost:5432/neflo?schema=public

# ---------- Google OAuth (same project pattern as Otuburu) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated allowlist. Leave empty to allow any Google account.
# e.g. ADMIN_EMAILS=filatei@gtsng.com
ADMIN_EMAILS=

# ---------- Email (Google Workspace SMTP relay, IP-trusted) ----------
# The relay accepts mail from the server's IP — NO SMTP auth needed.
# Leave SMTP_USER/SMTP_PASS empty; sending relies on IP trust + STARTTLS.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# EHLO/HELO greeting hostname — MUST be a real FQDN or Google's relay rejects
# the connection with "421-4.7.0 Try again later (EHLO)". Defaults to
# neflo.torama.money in code if unset.
SMTP_EHLO_NAME=neflo.torama.money
# From must be an address in your Workspace domain (allowed senders).
SMTP_FROM="Neflo <no-reply@torama.money>"

# ---------- Stablecoin rails ----------
# HD wallet mnemonic used to derive per-merchant deposit addresses.
# KEEP SECRET. Same handling discipline as Otuburu WALLET_MNEMONIC.
WALLET_MNEMONIC=
# TRON (TRC20) — TronGrid, same as Otuburu
TRONGRID_API_KEY=
TRON_FULL_HOST=https://api.trongrid.io
# EVM (ERC20 / USDC-USDT on Ethereum + Polygon) RPC endpoints.
# Use a dedicated provider — free public RPCs reject eth_getLogs (publicnode)
# or now require an API key (Ankr). A free Alchemy app gives reliable https + wss.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Optional WebSocket endpoints. When set, deposits are detected in REAL TIME via
# eth_subscribe (no polling flood); the timer scan stays on as a backfill.
ETH_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Confirmations before a deposit is credited
MIN_CONFIRMATIONS=12
# Polling-backfill getLogs window. Free RPC tiers (Alchemy) cap eth_getLogs to a
# small span — keep RANGE<=10 on the free tier. MAX_SPAN bounds how far back one
# tick scans (real-time WebSocket covers anything newer). Raise both on a paid tier.
EVM_GETLOGS_RANGE=10
EVM_GETLOGS_MAX_SPAN=200

# ---------- FX / settlement ----------
# Live USD->NGN comes from open.er-api.com hourly (no key). Boot seed only:
USD_TO_NGN_RATE=1600
# Spread we take on conversion, in basis points (e.g. 150 = 1.50%)
CONVERSION_SPREAD_BPS=150

# ---------- NGN rail: Squad (GTBank / HabariPay) ----------
# Leave SQUAD_SECRET_KEY empty to run the rail in MOCK mode (dev/demo).
# Sandbox base: https://sandbox-api-d.squadco.com  Live: https://api-d.squadco.com
SQUAD_SECRET_KEY=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com

# ---------- Internal ----------
# Server-to-server secret for the deposit monitor / cron endpoint
INTERNAL_SECRET=

# ---------- TapPay (contactless merchant collection) ----------
# Secret used to sign QR session tokens (HS256). Generate: openssl rand -base64 32
# Falls back to NEXTAUTH_SECRET if unset, but a dedicated secret is recommended.
TAPPAY_TOKEN_SECRET=
# Optional limit overrides (defaults shown). Amounts in kobo.
# TAPPAY_TTL_SECONDS=300            # QR validity (5 min)
# TAPPAY_MIN_KOBO=10000            # ₦100 minimum
# TAPPAY_PER_TXN_MAX_KOBO=1500000  # ₦15,000 per tap
# TAPPAY_DAILY_MAX_KOBO=5000000    # ₦50,000 per payer per day
# TAPPAY_MAX_CREATES_PER_MIN=10
# TAPPAY_MAX_PAY_ATTEMPTS=5
